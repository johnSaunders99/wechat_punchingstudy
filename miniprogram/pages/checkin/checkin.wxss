.container{padding:24rpx}.section-title{font-weight:600;margin-bottom:16rpx}
.type-list{display:flex;flex-wrap:wrap;gap:12rpx}
.type-item{padding:12rpx 20rpx;background:#fff;border-radius:12rpx}
.type-item.active{background:#1677ff;color:#fff}
.choose,.submit{margin-top:20rpx}
.preview{margin-top:16rpx;width:100%;height:360rpx;border-radius:12rpx}
.remark{margin-top:16rpx;background:#fff;border-radius:12rpx;padding:16rpx;width:100%;box-sizing:border-box}
