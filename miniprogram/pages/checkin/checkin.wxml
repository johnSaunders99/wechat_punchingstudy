<view class="container">
  <view class="section-title">请选择今日打卡项</view>
  <view class="type-list">
    <view class="type-item {{item.selected ? 'active' : ''}}" wx:for="{{types}}" wx:key="id" bindtap="toggleType" data-index="{{index}}">
      {{item.name}}
    </view>
  </view>

  <button class="choose" bindtap="chooseImage">选择图片/拍照</button>
  <image wx:if="{{tempFilePath}}" class="preview" src="{{tempFilePath}}" mode="aspectFill" />

  <textarea class="remark" maxlength="100" placeholder="备注（最多100字）" value="{{remark}}" bindinput="onRemarkInput"></textarea>
  <button class="submit" loading="{{submitting}}" bindtap="submit">提交打卡</button>
</view>
